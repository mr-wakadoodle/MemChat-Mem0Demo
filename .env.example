# ── MemChat Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Google AI Studio API key (free tier works fine)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Absolute or relative path where Qdrant stores its on-disk vector data.
# The directory will be created automatically if it doesn't exist.
QDRANT_PATH=./qdrant_storage

# Qdrant collection name (optional, default: "memchat")
QDRANT_COLLECTION=memchat

# Comma-separated list of allowed frontend origins for CORS.
# Defaults to localhost:3000 (CRA) and localhost:5173 (Vite) if not set.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Port for the FastAPI server (optional, default: 8000)
PORT=8000
